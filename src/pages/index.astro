---
import {
  site,
  ui,
  stats,
  researchAreas,
  members,
  publications,
  labLife,
} from '../data/lab';

import '../styles/global.css';

const currentYear = new Date().getFullYear();
const publicationKeywords = [
  { value: 'all', zh: '全部', en: 'All' },
  { value: 'AI药物发现', zh: 'AI药物发现', en: 'AI Drug Discovery' },
  { value: '生物信息学', zh: '生物信息学', en: 'Bioinformatics' },
  { value: '单细胞多组学', zh: '单细胞多组学', en: 'Single-cell Multi-omics' },
  { value: '系统生物学', zh: '系统生物学', en: 'Systems Biology' },
  { value: '医学AI', zh: '医学AI', en: 'Medical AI' },
];
const publicationYears = Array.from(new Set(publications.map((paper) => paper.year))).sort(
  (a, b) => Number(b) - Number(a)
);
const memberFilters = [
  { value: 'all', zh: '全部', en: 'All' },
  { value: 'PI', zh: 'PI', en: 'PI' },
  { value: '博士研究生', zh: '博士研究生', en: 'PhD Student' },
  { value: '研三', zh: '研三', en: 'MSc Year 3' },
  { value: '研二', zh: '研二', en: 'MSc Year 2' },
  { value: '研一', zh: '研一', en: 'MSc Year 1' },
  { value: '已毕业', zh: '已毕业', en: 'Alumni' },
];
const defaultMemberFilter = 'PI';
const initialMemberCount = members.filter((member) => member.category === defaultMemberFilter).length;
const memberCategoryLabels = {
  PI: { zh: 'PI', en: 'PI' },
  博士研究生: { zh: '博士研究生', en: 'PhD Student' },
  研三: { zh: '研三', en: 'MSc Year 3' },
  研二: { zh: '研二', en: 'MSc Year 2' },
  研一: { zh: '研一', en: 'MSc Year 1' },
  已毕业: { zh: '已毕业', en: 'Alumni' },
};
const getMemberCategoryLabel = (category: string) =>
  memberCategoryLabels[category as keyof typeof memberCategoryLabels] || { zh: category, en: category };
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="LiJin Lab focuses on AI drug discovery, single-cell multi-omics, and digital pathology."
    />
    <title>LiJin Lab | AI药物发现、单细胞多组学和数字病理团队</title>
  </head>

  <body
    data-title-zh="LiJin Lab | AI药物发现、单细胞多组学和数字病理团队"
    data-title-en="LiJin Lab | AI Drug Discovery, Omics and Pathology Lab"
  >
    <canvas id="particle-canvas" aria-hidden="true"></canvas>
    <div class="cursor-glow" aria-hidden="true"></div>

    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="#top" aria-label="LiJin Lab home">
          <span class="brand-mark">
            <img src="/images/lab-logo.png" alt="" />
          </span>
          <span class="brand-text">
            <strong data-i18n data-zh={site.labName.zh} data-en={site.labName.en}>{site.labName.zh}</strong>
            <small data-i18n data-zh={site.labNameZh.zh} data-en={site.labNameZh.en}>{site.labNameZh.zh}</small>
          </span>
        </a>

        <nav class="nav-links" aria-label="Primary navigation">
          <a href="#about" data-i18n data-zh="课题组简介" data-en="About">课题组简介</a>
          <a href="#research" data-i18n data-zh={ui.nav.research.zh} data-en={ui.nav.research.en}>{ui.nav.research.zh}</a>
          <a href="#people" data-i18n data-zh={ui.nav.people.zh} data-en={ui.nav.people.en}>{ui.nav.people.zh}</a>
          <a href="#publications" data-i18n data-zh={ui.nav.publications.zh} data-en={ui.nav.publications.en}>{ui.nav.publications.zh}</a>
          <a href="#news" data-i18n data-zh={ui.nav.news.zh} data-en={ui.nav.news.en}>{ui.nav.news.zh}</a>
          <a href="#contact" data-i18n data-zh={ui.nav.contact.zh} data-en={ui.nav.contact.en}>{ui.nav.contact.zh}</a>
        </nav>

        <button class="lang-toggle" type="button" data-lang-toggle aria-label="Switch language">
          <span class="lang-dot"></span>
          <span data-lang-toggle-label>{ui.buttons.language.zh}</span>
        </button>
      </div>
    </header>

    <main id="top">
      <section class="hero hero-full">
        <div class="hero-bg" aria-hidden="true">
          <img src="/images/bio-hero.png" alt="" />
        </div>
        <div class="hero-inner section-shell">
          <div class="hero-copy reveal">
          <p class="eyebrow">
            <span class="eyebrow-dot"></span>
            <span data-i18n data-zh={site.location.zh} data-en={site.location.en}>{site.location.zh}</span>
          </p>

          <h1 data-i18n data-zh={site.heroTitle.zh} data-en={site.heroTitle.en}>
            {site.heroTitle.zh}
          </h1>

          <p class="hero-description" data-i18n data-zh={site.heroDescription.zh} data-en={site.heroDescription.en}>
            {site.heroDescription.zh}
          </p>

          <div class="hero-actions">
            <a class="button button-primary" href="#research" data-i18n data-zh={ui.buttons.explore.zh} data-en={ui.buttons.explore.en}>
              {ui.buttons.explore.zh}
            </a>
            <a class="button button-secondary" href="#publications" data-i18n data-zh={ui.buttons.join.zh} data-en={ui.buttons.join.en}>
              {ui.buttons.join.zh}
            </a>
          </div>

          <div class="hero-stats">
            {stats.map((item) => (
              <div class="hero-stat-card">
                <strong>{item.value}</strong>
                <span data-i18n data-zh={item.label.zh} data-en={item.label.en}>{item.label.zh}</span>
              </div>
            ))}
          </div>
          </div>
        </div>
      </section>
      
      <section id="about" class="module-section module-section-about page-section">
        <div class="about-section section-shell">
        <div class="about-media about-photo-card reveal" aria-label="LiJin Lab team photo">
          <img src="/images/team-photo.jpg" alt="LiJin Lab 团队合影" />
        </div>

        <div class="about-copy reveal">
          <p class="eyebrow" data-i18n data-zh="Laboratory Introduction" data-en="Laboratory Introduction">
            Laboratory Introduction
          </p>

          <h2
            data-i18n
            data-zh="AI药物发现、单细胞多组学和数字病理团队"
            data-en="AI Drug Discovery, Omics and Pathology Lab"
          >
            AI药物发现、单细胞多组学和数字病理团队
          </h2>

          <p
            data-i18n
            data-zh="本研究团队现有教师4人，其中教授2人、博士4人，现有博士研究生2人、硕士研究生11人，长期致力于人工智能在生物医学大数据领域的研究。"
            data-en="The team currently has five faculty members, including two professors and four PhD holders, together with two doctoral students and eleven master students. The team has long focused on artificial intelligence for biomedical big data."
          >
            本研究团队现有教师4人，其中教授2人、博士4人，现有博士研究生2人、硕士研究生11人，长期致力于人工智能在生物医学大数据领域的研究。
          </p>

          <p
            data-i18n
            data-zh="团队主持国家自然科学基金2项、省自然科学基金6项，发表SCI论文60余篇，围绕 AI 药物发现、单细胞多组学和数字病理开展方法创新、资源建设与临床转化探索。"
            data-en="The team has led two National Natural Science Foundation of China projects and six provincial natural science foundation projects, and has published more than 60 SCI papers across AI drug discovery, single-cell multi-omics and digital pathology."
          >
            团队主持国家自然科学基金2项、省自然科学基金6项，发表SCI论文60余篇，围绕 AI 药物发现、单细胞多组学和数字病理开展方法创新、资源建设与临床转化探索。
          </p>

          <div class="about-feature-grid">
            <div class="about-feature-card">
              <strong data-i18n data-zh="研究定位" data-en="Research Scope">研究定位</strong>
              <span
                data-i18n
                data-zh="生物医学大数据与智能医学交叉"
                data-en="Biomedical big data and intelligent medicine"
              >
                生物医学大数据与智能医学交叉
              </span>
            </div>

            <div class="about-feature-card">
              <strong data-i18n data-zh="方法重点" data-en="Methodological Focus">方法重点</strong>
              <span
                data-i18n
                data-zh="AI建模、统计学习、多组学整合与图像分析"
                data-en="AI modeling, statistical learning, multi-omics integration and image analysis"
              >
                AI建模、统计学习、多组学整合与图像分析
              </span>
            </div>

            <div class="about-feature-card">
              <strong data-i18n data-zh="转化目标" data-en="Translational Aim">转化目标</strong>
              <span
                data-i18n
                data-zh="服务药物发现、免疫治疗、数字病理与临床转化"
                data-en="Drug discovery, immunotherapy, digital pathology and clinical translation"
              >
                服务药物发现、免疫治疗、数字病理与临床转化
              </span>
            </div>
          </div>
        </div>
        </div>
      </section>

      <section id="research" class="module-section module-section-soft page-section">
        <div class="section-shell">
        <div class="section-heading reveal">
          <p class="eyebrow" data-i18n data-zh={ui.sections.researchEyebrow.zh} data-en={ui.sections.researchEyebrow.en}>
            {ui.sections.researchEyebrow.zh}
          </p>
          <h2 data-i18n data-zh={ui.sections.researchTitle.zh} data-en={ui.sections.researchTitle.en}>
            {ui.sections.researchTitle.zh}
          </h2>
          <p data-i18n data-zh={ui.sections.researchDesc.zh} data-en={ui.sections.researchDesc.en}>
            {ui.sections.researchDesc.zh}
          </p>
        </div>

        <div class="card-grid three-columns">
          {researchAreas.map((area) => (
            <article class="research-card reveal tilt-card">
              <div class="card-icon">{area.icon}</div>
              <h3 data-i18n data-zh={area.title.zh} data-en={area.title.en}>{area.title.zh}</h3>
              <p data-i18n data-zh={area.description.zh} data-en={area.description.en}>{area.description.zh}</p>
              <ul>
                {area.bullets.map((bullet) => (
                  <li data-i18n data-zh={bullet.zh} data-en={bullet.en}>{bullet.zh}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
        </div>
      </section>

      <section id="people" class="module-section page-section">
        <div class="section-shell">
        <div class="people-browser reveal" data-member-browser>
          <div class="people-header">
            <div>
              <p class="eyebrow" data-i18n data-zh={ui.sections.peopleEyebrow.zh} data-en={ui.sections.peopleEyebrow.en}>
                {ui.sections.peopleEyebrow.zh}
              </p>
              <h2 data-i18n data-zh={ui.sections.peopleTitle.zh} data-en={ui.sections.peopleTitle.en}>
                {ui.sections.peopleTitle.zh}
              </h2>
              
            </div>
            <div class="people-count">
              <strong data-member-count>{initialMemberCount}</strong>
              <span data-i18n data-zh="成员条目" data-en="Members">成员条目</span>
            </div>
          </div>

          <div class="people-filter-bar" aria-label="Member filters">
            {memberFilters.map((filter) => (
              <button
                class={`member-filter ${filter.value === defaultMemberFilter ? 'is-active' : ''}`}
                type="button"
                data-member-filter={filter.value}
                data-i18n
                data-zh={filter.zh}
                data-en={filter.en}
              >
                {filter.zh}
              </button>
            ))}
          </div>

          <div class="people-grid">
            {members.map((member) => (
              <a
                class="member-card reveal"
                href={`/members/${member.slug}/`}
                data-member-card
                data-category={member.category}
                hidden={member.category !== defaultMemberFilter}
              >
                <div class="member-topline">
                  <span
                    class="member-category"
                    data-i18n
                    data-zh={getMemberCategoryLabel(member.category).zh}
                    data-en={getMemberCategoryLabel(member.category).en}
                  >
                    {getMemberCategoryLabel(member.category).zh}
                  </span>
                  <span
                    class="member-email"
                    data-i18n
                    data-zh={member.email ? '邮箱' : '主页'}
                    data-en={member.email ? 'Email' : 'Profile'}
                  >
                    {member.email ? '邮箱' : '主页'}
                  </span>
                </div>
                <div class="member-main">
                  <img src={member.avatar} alt="" loading="lazy" />
                  <div>
                    <h3 data-i18n data-zh={member.name.zh} data-en={member.name.en}>{member.name.zh}</h3>
                    <p class="member-role" data-i18n data-zh={member.role.zh} data-en={member.role.en}>{member.role.zh}</p>
                  </div>
                </div>
                <p class="member-focus" data-i18n data-zh={member.focus.zh} data-en={member.focus.en}>{member.focus.zh}</p>
                <span class="member-card-action" data-i18n data-zh="查看个人介绍" data-en="View Profile">查看个人介绍</span>
              </a>
            ))}
          </div>
          <p
            class="people-empty"
            data-member-empty
            data-i18n
            data-zh="当前分类下暂无成员，后续名单补充后会显示在这里。"
            data-en="No members are available in this category yet."
            hidden
          >
            当前分类下暂无成员，后续名单补充后会显示在这里。
          </p>
        </div>
        </div>
      </section>

      <section id="publications" class="module-section module-section-soft page-section">
        <div class="section-shell">
        <div class="publication-browser reveal" data-publication-browser>
          <div class="publication-header">
            <div>
              <p class="eyebrow publication-eyebrow" data-i18n data-zh={ui.sections.publicationsEyebrow.zh} data-en={ui.sections.publicationsEyebrow.en}>
                {ui.sections.publicationsEyebrow.zh}
              </p>
              <h2 data-i18n data-zh={ui.sections.publicationsTitle.zh} data-en={ui.sections.publicationsTitle.en}>
                {ui.sections.publicationsTitle.zh}
              </h2>
              
            </div>
          </div>

          <div class="publication-toolbar" aria-label="Publication filters">
            <div class="publication-search-wrap">
              <input
                class="publication-search"
                type="search"
                placeholder="搜索题名、作者、期刊或 DOI"
                aria-label="搜索题名、作者、期刊或 DOI"
                data-i18n-attrs
                data-placeholder-zh="搜索题名、作者、期刊或 DOI"
                data-placeholder-en="Search title, authors, journal, or DOI"
                data-aria-label-zh="搜索题名、作者、期刊或 DOI"
                data-aria-label-en="Search title, authors, journal, or DOI"
                data-pub-search
              />
            </div>

            <div class="publication-filter-group" aria-label="Keyword filters">
              {publicationKeywords.map((keyword, index) => (
                <button
                  class={`pub-filter ${index === 0 ? 'is-active' : ''}`}
                  type="button"
                  data-pub-keyword={keyword.value}
                  data-i18n
                  data-zh={keyword.zh}
                  data-en={keyword.en}
                >
                  {keyword.zh}
                </button>
              ))}
            </div>

            <div class="publication-filter-group" aria-label="Year filters">
              <button
                class="pub-filter is-active"
                type="button"
                data-pub-year="all"
                data-i18n
                data-zh="全部年份"
                data-en="All Years"
              >
                全部年份
              </button>
              {publicationYears.map((year) => (
                <button class="pub-filter" type="button" data-pub-year={year}>{year}</button>
              ))}
            </div>
          </div>

          <div class="publication-result-line">
            <span data-result-label data-zh-prefix="共 " data-zh-suffix=" 篇论文" data-en-prefix="" data-en-suffix=" papers">
              <span data-result-prefix>共 </span><strong data-pub-count>{publications.length}</strong><span data-result-suffix> 篇论文</span>
            </span>
            <span data-i18n data-zh="按关键词和年份实时筛选" data-en="Filter by keyword and year">按关键词和年份实时筛选</span>
          </div>

          <div class="publication-list">
            {publications.map((paper) => {
              const keywords = paper.tags.map((tag) => tag.zh).join('|');
              const searchText = [
                paper.year,
                paper.title.zh,
                paper.title.en,
                paper.authors,
                paper.venue.zh,
                paper.venue.en,
                paper.doi || '',
                keywords,
              ].join(' ');

              return (
                <article
                  class="publication-item reveal"
                  data-pub-card
                  data-year={paper.year}
                  data-keywords={keywords}
                  data-search={searchText}
                >
                  <div class="publication-year">{paper.year}</div>
                  <div class="publication-body">
                    <a class="publication-title" href={paper.link} target="_blank" rel="noopener noreferrer">
                      <span data-i18n data-zh={paper.title.zh} data-en={paper.title.en}>{paper.title.zh}</span>
                    </a>
                    <p class="publication-authors">{paper.authors}</p>
                    <p class="venue" data-i18n data-zh={paper.venue.zh} data-en={paper.venue.en}>{paper.venue.zh}</p>
                    <div class="publication-meta-row">
                      <div class="tag-row">
                        <span data-i18n data-zh="论文" data-en="Paper">论文</span>
                        {paper.tags.map((tag) => (
                          <span data-i18n data-zh={tag.zh} data-en={tag.en}>{tag.zh}</span>
                        ))}
                        {paper.representative && <span class="tag-highlight" data-i18n data-zh="代表性" data-en="Representative">代表性</span>}
                      </div>
                      {paper.doi && (
                        <a class="doi-link" href={paper.link} target="_blank" rel="noopener noreferrer">
                          DOI
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>

          <p
            class="publication-empty"
            data-pub-empty
            data-i18n
            data-zh="未找到匹配的论文，请调整关键词、年份或搜索内容。"
            data-en="No matching publications were found. Try another keyword, year, or search term."
            hidden
          >
            未找到匹配的论文，请调整关键词、年份或搜索内容。
          </p>
        </div>
        </div>
      </section>

      <section id="news" class="module-section page-section">
        <div class="section-shell">
          <div class="lab-life-layout reveal">
            <div class="lab-life-intro">
              <p class="eyebrow" data-i18n data-zh={ui.sections.newsEyebrow.zh} data-en={ui.sections.newsEyebrow.en}>
                {ui.sections.newsEyebrow.zh}
              </p>
              <h2 data-i18n data-zh={ui.sections.newsTitle.zh} data-en={ui.sections.newsTitle.en}>
                {ui.sections.newsTitle.zh}
              </h2>
              
            </div>

            <div class="lab-life-grid">
              {labLife.map((item) => (
                <article class={`lab-life-card ${item.feature ? 'is-feature' : ''}`}>
                  <img src={item.image} alt={item.title.zh} loading="lazy" />
                  <div class="lab-life-caption">
                    <time>{item.year}</time>
                    <h3 data-i18n data-zh={item.title.zh} data-en={item.title.en}>{item.title.zh}</h3>
                    <p data-i18n data-zh={item.summary.zh} data-en={item.summary.en}>{item.summary.zh}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="module-section module-section-contact page-section">
        <div class="contact-section section-shell reveal">
          <div>
            <p class="eyebrow" data-i18n data-zh={ui.sections.contactEyebrow.zh} data-en={ui.sections.contactEyebrow.en}>
              {ui.sections.contactEyebrow.zh}
            </p>
            <h2 data-i18n data-zh={ui.sections.contactTitle.zh} data-en={ui.sections.contactTitle.en}>
              {ui.sections.contactTitle.zh}
            </h2>
            <p
              class="contact-intro"
              data-i18n
              data-zh="本团队招收生物学（生物物理学）博士研究生，智能科学与技术（学硕）和电子信息（专硕）硕士研究生，欢迎报考、交流与合作。"
              data-en="The team welcomes PhD students in Biology (Biophysics), and master students in Intelligent Science and Technology or Electronic Information. Applications, exchange and collaboration are welcome."
            >
              本团队招收生物学（生物物理学）博士研究生，智能科学与技术（学硕）和电子信息（专硕）硕士研究生，欢迎报考、交流与合作。
            </p>
          </div>
          <div class="contact-card-grid">
            <article class="contact-info-card">
              <span class="contact-icon">
                <img src="/images/icons/address.png" alt="" loading="lazy" />
              </span>
              <div>
                <strong data-i18n data-zh="地址" data-en="Address">地址</strong>
                <span data-i18n data-zh={site.address.zh} data-en={site.address.en}>{site.address.zh}</span>
              </div>
            </article>
            <article class="contact-info-card">
              <span class="contact-icon">
                <img src="/images/icons/unit.png" alt="" loading="lazy" />
              </span>
              <div>
                <strong data-i18n data-zh="单位" data-en="Affiliation">单位</strong>
                <span data-i18n data-zh={site.unit.zh} data-en={site.unit.en}>{site.unit.zh}</span>
              </div>
            </article>
            <article class="contact-info-card">
              <span class="contact-icon">
                <img src="/images/icons/email.png" alt="" loading="lazy" />
              </span>
              <div>
                <strong data-i18n data-zh="邮箱" data-en="Email">邮箱</strong>
                <a href={`mailto:${site.email}`}>{site.email}</a>
              </div>
            </article>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <span>Copyright © {currentYear} Li Lab. All rights reserved.</span>
      <span>Designed for academic communication and collaboration.</span>
    </footer>

    <a
      class="back-to-top"
      href="#top"
      aria-label="返回顶部"
      data-i18n-attrs
      data-aria-label-zh="返回顶部"
      data-aria-label-en="Back to top"
    >
      ↑
    </a>

    <script is:inline>
      (() => {
        const key = 'li-lab-language';
        const textNodes = document.querySelectorAll('[data-i18n]');
        const attrNodes = document.querySelectorAll('[data-i18n-attrs]');
        const resultLabels = document.querySelectorAll('[data-result-label]');
        const toggle = document.querySelector('[data-lang-toggle]');
        const toggleLabel = document.querySelector('[data-lang-toggle-label]');
        const body = document.body;

        const applyLanguage = (lang) => {
          const safeLang = lang === 'en' ? 'en' : 'zh';
          document.documentElement.lang = safeLang === 'en' ? 'en' : 'zh-CN';

          textNodes.forEach((node) => {
            const value = node.dataset[safeLang];
            if (value) node.textContent = value;
          });

          attrNodes.forEach((node) => {
            const placeholder = node.dataset[`placeholder${safeLang === 'en' ? 'En' : 'Zh'}`];
            const ariaLabel = node.dataset[`ariaLabel${safeLang === 'en' ? 'En' : 'Zh'}`];
            if (placeholder) node.setAttribute('placeholder', placeholder);
            if (ariaLabel) node.setAttribute('aria-label', ariaLabel);
          });

          resultLabels.forEach((node) => {
            const prefix = node.dataset[`${safeLang}Prefix`];
            const suffix = node.dataset[`${safeLang}Suffix`];
            const prefixNode = node.querySelector('[data-result-prefix]');
            const suffixNode = node.querySelector('[data-result-suffix]');
            if (prefixNode && prefix !== undefined) prefixNode.textContent = prefix;
            if (suffixNode && suffix !== undefined) suffixNode.textContent = suffix;
          });

          if (toggleLabel) {
            toggleLabel.textContent = safeLang === 'en' ? '中文' : 'EN';
          }

          if (body) {
            const title = safeLang === 'en' ? body.dataset.titleEn : body.dataset.titleZh;
            if (title) document.title = title;
          }

          localStorage.setItem(key, safeLang);
        };

        applyLanguage(localStorage.getItem(key) || 'zh');

        if (toggle) {
          toggle.addEventListener('click', () => {
            const current = localStorage.getItem(key) || 'zh';
            applyLanguage(current === 'zh' ? 'en' : 'zh');
          });
        }
      })();

      (() => {
        const browser = document.querySelector('[data-publication-browser]');
        if (!browser) return;

        const keywordButtons = Array.from(browser.querySelectorAll('[data-pub-keyword]'));
        const yearButtons = Array.from(browser.querySelectorAll('[data-pub-year]'));
        const cards = Array.from(browser.querySelectorAll('[data-pub-card]'));
        const search = browser.querySelector('[data-pub-search]');
        const count = browser.querySelector('[data-pub-count]');
        const empty = browser.querySelector('[data-pub-empty]');
        const state = {
          keyword: 'all',
          year: 'all',
          query: '',
        };

        const normalize = (value) => (value || '').toString().trim().toLowerCase();

        const updateActive = (buttons, attr, value) => {
          buttons.forEach((button) => {
            button.classList.toggle('is-active', button.dataset[attr] === value);
          });
        };

        const applyFilters = () => {
          let visibleCount = 0;
          const query = normalize(state.query);

          cards.forEach((card) => {
            const cardKeywords = (card.dataset.keywords || '').split('|');
            const keywordMatch = state.keyword === 'all' || cardKeywords.includes(state.keyword);
            const yearMatch = state.year === 'all' || card.dataset.year === state.year;
            const searchMatch = !query || normalize(card.dataset.search).includes(query);
            const shouldShow = keywordMatch && yearMatch && searchMatch;

            card.hidden = !shouldShow;
            if (shouldShow) visibleCount += 1;
          });

          if (count) count.textContent = visibleCount;
          if (empty) empty.hidden = visibleCount !== 0;
          updateActive(keywordButtons, 'pubKeyword', state.keyword);
          updateActive(yearButtons, 'pubYear', state.year);
        };

        keywordButtons.forEach((button) => {
          button.addEventListener('click', () => {
            state.keyword = button.dataset.pubKeyword || 'all';
            applyFilters();
          });
        });

        yearButtons.forEach((button) => {
          button.addEventListener('click', () => {
            state.year = button.dataset.pubYear || 'all';
            applyFilters();
          });
        });

        if (search) {
          search.addEventListener('input', () => {
            state.query = search.value;
            applyFilters();
          });
        }

        applyFilters();
      })();

      (() => {
        const browser = document.querySelector('[data-member-browser]');
        if (!browser) return;

        const buttons = Array.from(browser.querySelectorAll('[data-member-filter]'));
        const cards = Array.from(browser.querySelectorAll('[data-member-card]'));
        const count = browser.querySelector('[data-member-count]');
        const empty = browser.querySelector('[data-member-empty]');
        const storageKey = 'li-lab-member-filter';
        const validFilters = new Set(buttons.map((button) => button.dataset.memberFilter || 'all'));

        const getInitialFilter = () => {
          const params = new URLSearchParams(window.location.search);
          const queryFilter = params.get('memberFilter');
          const savedFilter = sessionStorage.getItem(storageKey);

          if (queryFilter && validFilters.has(queryFilter)) return queryFilter;
          if (savedFilter && validFilters.has(savedFilter)) return savedFilter;
          return 'PI';
        };

        const makePeopleUrl = (category) => {
          const url = new URL(window.location.href);
          if (category && category !== 'PI') {
            url.searchParams.set('memberFilter', category);
          } else {
            url.searchParams.delete('memberFilter');
          }
          url.hash = 'people';
          return url;
        };

        const applyFilter = (category, options = {}) => {
          const safeCategory = validFilters.has(category) ? category : 'PI';
          let visibleCount = 0;

          cards.forEach((card) => {
            const shouldShow = safeCategory === 'all' || card.dataset.category === safeCategory;
            card.hidden = !shouldShow;
            if (shouldShow) visibleCount += 1;
          });

          buttons.forEach((button) => {
            button.classList.toggle('is-active', button.dataset.memberFilter === safeCategory);
          });

          if (count) count.textContent = visibleCount;
          if (empty) empty.hidden = visibleCount !== 0;

          sessionStorage.setItem(storageKey, safeCategory);
          cards.forEach((card) => {
            const href = card.getAttribute('href');
            if (!href) return;
            const detailUrl = new URL(href, window.location.origin);
            detailUrl.searchParams.set('from', 'people');
            detailUrl.searchParams.set('memberFilter', safeCategory);
            card.setAttribute('href', `${detailUrl.pathname}${detailUrl.search}`);
          });

          if (options.syncUrl) {
            window.history.replaceState(null, '', makePeopleUrl(safeCategory));
          }
        };

        buttons.forEach((button) => {
          button.addEventListener('click', () => {
            applyFilter(button.dataset.memberFilter || 'all', { syncUrl: true });
          });
        });

        applyFilter(getInitialFilter());
      })();

      (() => {
        const revealEls = document.querySelectorAll('.reveal');

        if (!('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );

        revealEls.forEach((el) => observer.observe(el));
      })();

      (() => {
        const glow = document.querySelector('.cursor-glow');
        if (!glow) return;

        window.addEventListener('pointermove', (event) => {
          glow.style.setProperty('--x', `${event.clientX}px`);
          glow.style.setProperty('--y', `${event.clientY}px`);
          glow.classList.add('is-active');
        });

        window.addEventListener('pointerleave', () => {
          glow.classList.remove('is-active');
        });
      })();

      (() => {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion) return;

        const canvas = document.getElementById('particle-canvas');
        if (!canvas) return;

        const ctx = canvas.getContext('2d');
        let width = 0;
        let height = 0;
        let particles = [];
        let frame = null;

        const createParticles = () => {
          const count = window.innerWidth < 640 ? 14 : window.innerWidth < 1024 ? 24 : 36;
          particles = Array.from({ length: count }, () => ({
            x: Math.random() * width,
            y: Math.random() * height,
            vx: (Math.random() - 0.5) * 0.16,
            vy: (Math.random() - 0.5) * 0.16,
            r: Math.random() * 1.2 + 0.7,
          }));
        };

        const resize = () => {
          const ratio = Math.min(window.devicePixelRatio || 1, 2);
          width = window.innerWidth;
          height = window.innerHeight;
          canvas.width = Math.floor(width * ratio);
          canvas.height = Math.floor(height * ratio);
          canvas.style.width = `${width}px`;
          canvas.style.height = `${height}px`;
          ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
          createParticles();
        };

        const draw = () => {
          ctx.clearRect(0, 0, width, height);

          particles.forEach((p, index) => {
            p.x += p.vx;
            p.y += p.vy;

            if (p.x < 0) p.x = width;
            if (p.x > width) p.x = 0;
            if (p.y < 0) p.y = height;
            if (p.y > height) p.y = 0;

            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(43, 143, 137, 0.16)';
            ctx.fill();

            for (let j = index + 1; j < particles.length; j++) {
              const q = particles[j];
              const dx = p.x - q.x;
              const dy = p.y - q.y;
              const dist = Math.sqrt(dx * dx + dy * dy);

              if (dist < 105) {
                ctx.beginPath();
                ctx.moveTo(p.x, p.y);
                ctx.lineTo(q.x, q.y);
                ctx.strokeStyle = `rgba(43, 143, 137, ${0.04 * (1 - dist / 105)})`;
                ctx.stroke();
              }
            }
          });

          frame = requestAnimationFrame(draw);
        };

        window.addEventListener('resize', resize);
        resize();
        draw();

        window.addEventListener('beforeunload', () => {
          if (frame) cancelAnimationFrame(frame);
        });
      })();
    </script>
  </body>
</html>
